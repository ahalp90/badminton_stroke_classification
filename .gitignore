# ---------------------------------------------------------------------------
# Project operational dirs split across two roots — see runtime/README.md
# and training/README.md for the full layout. Directory structure tracked
# via .gitkeep; contents not.
#
#   runtime/                — what the deployed application needs.
#     deployed/<arch>/      — live model package (manifest.yaml + best.pt).
#     checkpoints/<dep>/    — third-party perception used at inference
#                             (yolo11, tracknetv3).
#     uploads/              — user-uploaded inference videos.
#     jobs/                 — per-job inference artefacts (frame thumbnails,
#                             softmax). Persist for the lifetime of the
#                             corresponding jobs row in state/inference.db.
#     state/                — backend SQLite (inference.db).
#
#   training/               — never on a serving host.
#     data/                 — source training data (ShuttleSet).
#     <arch>/cache/         — re-derivable per-architecture preprocessing.
#     <arch>/experiments/   — training run manifests, metrics, weights.
#                             Promote a chosen run to deployed via
#                             `ln -snf training/<arch>/experiments/<run_id> \
#                                       runtime/deployed/<arch>` (local) or
#                             rsync to the serving host's runtime/deployed/<arch>/.
# ---------------------------------------------------------------------------

# runtime/
runtime/deployed/bric/*
!runtime/deployed/bric/.gitkeep

runtime/checkpoints/tracknetv3/*
!runtime/checkpoints/tracknetv3/.gitkeep
runtime/checkpoints/yolo11/*
!runtime/checkpoints/yolo11/.gitkeep

runtime/uploads/*
!runtime/uploads/.gitkeep

runtime/jobs/*
!runtime/jobs/.gitkeep

runtime/state/*
!runtime/state/.gitkeep

# training/
training/data/shuttleset/clips/*
!training/data/shuttleset/clips/.gitkeep
training/data/shuttleset/rally_clips/*
!training/data/shuttleset/rally_clips/.gitkeep
training/data/shuttleset/raw_video/*
!training/data/shuttleset/raw_video/.gitkeep

training/bric/cache/players/*
!training/bric/cache/players/.gitkeep
training/bric/cache/shuttle/*
!training/bric/cache/shuttle/.gitkeep
training/bric/cache/rgb/*
!training/bric/cache/rgb/.gitkeep
training/bric/cache/validation/

training/bric/experiments/*
!training/bric/experiments/.gitkeep

# Ultralytics auto-downloads YOLO weights into the current working directory
# (or to ~/.cache/ultralytics/) on first use. Catch any that land in the repo
# root regardless. Production code should explicitly load from
# runtime/checkpoints/yolo11/.
yolo*.pt
*.engine

# Ultralytics training/predict default output dir
runs/

# Video uploads — contents are runtime artefacts, not tracked. Directory is tracked via .gitkeep.
uploads/*
!uploads/.gitkeep

# Claude Code local workspace settings
.claude/
frontend/.claude/

# Local-only large data SCP'd from Engelbart (542MB collations)
scratch/bst_inputs/