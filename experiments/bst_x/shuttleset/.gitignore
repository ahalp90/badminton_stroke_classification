
# Model weights for the bst_x subtree.
# Scoped here (not the repo-root .gitignore) so per-run tactical unignores
# don't clutter the global file as more runs pile up.

# Run layout: experiments/<run_id>/.
# manifest.yaml, best_model_id.txt, and TB event files stay tracked (all
# small, source of truth for hparams + results + training curves). Only
# weights (large) are ignored by default; tactical unignores below pick the
# best checkpoint per run.
*/weights/*

# Aim experiment tracker cache (optional UI, local only; created in cwd when
# aim_backfill.py or `aim up` runs from src/bst_x/).
.aim/

# Best checkpoints per run (tactical unignores).
# All historical best weights are now archived (training archive + published
# model fork, not in-tree; see MODELS.md). Only the curated champions kept
# in-repo are unignored below.

# foundation_chang_baseline: pre-tracker baseline (paper hyperparams + TrackNetV3 WITH inpaint). S2 best.
!foundation_chang_baseline/weights/bst_cg_ap_JnB_bone_between_2_hits_with_max_limits_seq_100_merged_25_2.pt

# run_20260530_192738_970644: bst_12, v2 split (the 12 base BST strokes, side-agnostic). Best S4. Taxon-pinned prediction cell.
!run_20260530_192738_970644/weights/bst_x_JnB_bone_between_2_hits_with_max_limits_seq_100_bst_12_4.pt

# run_20260530_210600_435552: bst_25, baseline split, unknown kept (original bst split w/ unknown). Best S1. Taxon-pinned prediction cell.
!run_20260530_210600_435552/weights/bst_x_JnB_bone_between_2_hits_with_max_limits_seq_100_bst_25.pt

# run_20260530_225714_593038: bst_24, baseline split, unknown dropped (original bst split w/o unknown). Best S5. Taxon-pinned prediction cell.
!run_20260530_225714_593038/weights/bst_x_JnB_bone_between_2_hits_with_max_limits_seq_100_bst_24_5.pt

# run_20260531_005535_005154: une_v1_14, v2 split (bst_12 + wrist_smash + passive_drop). Best S3. Taxon-pinned prediction cell.
!run_20260531_005535_005154/weights/bst_x_JnB_bone_between_2_hits_with_max_limits_seq_100_une_v1_14_3.pt

# run_20260601_153738_936523: shuttleset_18, v2 split, wd 4e-1, gate off. Best S5 (test macro/min 0.672/0.000).
